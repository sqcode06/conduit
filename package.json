{
  "name": "conduit",
  "version": "0.1.0",
  "private": true,
  "description": "CONDUIT — single-use capability-link file exchange on Cloudflare Workers (R2 + D1 + Access).",
  "license": "MIT",
  "author": "sqcode",
  "homepage": "https://conduit.sqcode.dev",
  "repository": { "type": "git", "url": "https://github.com/sqcode06/conduit.git" },
  "bugs": { "url": "https://github.com/sqcode06/conduit/issues" },
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply conduit-meta --local",
    "db:migrate:remote": "wrangler d1 migrations apply conduit-meta --remote --env production"
  },
  "dependencies": {
    "hono": "^4.12.27",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.19",
    "@cloudflare/workers-types": "^4.20260625.1",
    "typescript": "^6.0.3",
    "vitest": "~4.1.9",
    "wrangler": "^4.104.0"
  }
}
